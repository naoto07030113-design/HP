# ── Supabase（クリニック用プロジェクト）──────────────────────
# Supabase Dashboard → Project Settings → API から取得
NEXT_PUBLIC_CLINIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_CLINIC_SUPABASE_ANON_KEY=your_anon_key

# サーバーサイド（初診予約API）用。設定するとRLSをバイパスして確実に登録できる。
# 未設定の場合は anon キーで動作（setup.sql の anon INSERT ポリシーに依存）
CLINIC_SERVICE_ROLE_KEY=

# ── LINE通知（任意）──────────────────────────────────────────
# 新規予約時にスタッフのLINE公式アカウントへ通知する場合に設定
# 形式: {"<clinicのUUID>": "<チャネルアクセストークン>", ...}
LINE_CHANNEL_TOKENS=
